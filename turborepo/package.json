{
  "name": "turborepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "research": "tsx scripts/run-agent.ts",
    "research:year": "tsx scripts/run-agent.ts --year"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@tavily/core": "^0.3.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "tsx": "^4.19.2",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@10.33.1",
  "engines": {
    "node": ">=18"
  }
}
